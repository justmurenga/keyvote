{
  "name": "myvote-kenya",
  "version": "1.0.0",
  "private": true,
  "description": "Election Management System for Kenya",
  "scripts": {
    "dev": "turbo dev",
    "build": "turbo build",
    "lint": "turbo lint",
    "typecheck": "turbo typecheck",
    "test": "turbo test",
    "clean": "turbo clean && rimraf node_modules",
    "db:generate": "turbo db:generate",
    "db:migrate": "turbo db:migrate",
    "db:seed": "turbo db:seed",
    "import:electoral": "tsx scripts/import-electoral-data.ts",
    "import:verify": "tsx scripts/verify-import.ts",
    "format": "prettier --write \"**/*.{ts,tsx,md,json}\"",
    "prepare": "husky"
  },
  "devDependencies": {
    "@types/node": "^20.11.0",
    "husky": "^9.0.0",
    "lint-staged": "^15.2.0",
    "prettier": "^3.2.0",
    "prettier-plugin-tailwindcss": "^0.5.11",
    "rimraf": "^5.0.5",
    "tsx": "^4.7.0",
    "turbo": "^2.0.0",
    "typescript": "^5.3.0"
  },
  "packageManager": "pnpm@8.14.0",
  "engines": {
    "node": ">=20.0.0",
    "pnpm": ">=8.0.0"
  },
  "lint-staged": {
    "*.{ts,tsx}": [
      "prettier --write",
      "eslint --fix"
    ],
    "*.{json,md}": [
      "prettier --write"
    ]
  },
  "dependencies": {
    "@supabase/node-fetch": "^2.6.13",
    "@supabase/supabase-js": "2.39.8",
    "xlsx": "^0.18.5"
  },
  "pnpm": {
    "overrides": {
      "@supabase/supabase-js": "2.39.8",
      "@supabase/postgrest-js": "1.9.2"
    }
  }
}
