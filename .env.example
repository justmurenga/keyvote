# ===========================================
# myVote Kenya - Environment Variables
# ===========================================
# Copy this file to .env and fill in your values
# cp .env.example .env
#
# For Digital Ocean App Platform, set these as
# app-level environment variables or secrets.
# ===========================================

# ===========================================
# SUPABASE
# ===========================================
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-supabase-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-supabase-service-role-key
DATABASE_URL=postgresql://postgres:password@host:6543/postgres

# ===========================================
# AFRICA'S TALKING (SMS & USSD)
# ===========================================
AT_API_KEY=your-africastalking-api-key
AT_USERNAME=your-africastalking-username
AT_SENDER_ID=MYVOTE
AT_USSD_CODE=*384*VOTE#

# ===========================================
# SAFARICOM DARAJA (M-PESA)
# ===========================================
MPESA_CONSUMER_KEY=your-consumer-key
MPESA_CONSUMER_SECRET=your-consumer-secret
MPESA_PASSKEY=your-passkey
MPESA_SHORTCODE=your-shortcode
MPESA_INITIATOR_NAME=your-initiator-name
MPESA_INITIATOR_PASSWORD=your-initiator-password
MPESA_ENVIRONMENT=sandbox
MPESA_CALLBACK_URL=https://your-domain.com/api/webhooks/mpesa

# ===========================================
# WHATSAPP (360DIALOG)
# ===========================================
WHATSAPP_API_KEY=your-whatsapp-api-key
WHATSAPP_PHONE_NUMBER_ID=your-phone-number-id

# ===========================================
# APPLICATION
# ===========================================
NEXT_PUBLIC_APP_URL=http://localhost:3000
NEXT_PUBLIC_APP_NAME=myVote Kenya

# ===========================================
# MONITORING & ANALYTICS
# ===========================================
SENTRY_DSN=your-sentry-dsn
NEXT_PUBLIC_POSTHOG_KEY=your-posthog-key
NEXT_PUBLIC_POSTHOG_HOST=https://app.posthog.com

# ===========================================
# DIGITAL OCEAN (CI/CD - set in GitHub Secrets)
# ===========================================
# DIGITALOCEAN_ACCESS_TOKEN=your-do-token
# DO_APP_ID=your-app-id
# DO_STAGING_APP_ID=your-staging-app-id

# ===========================================
# SUPABASE CLI (CI/CD - set in GitHub Secrets)
# ===========================================
# SUPABASE_ACCESS_TOKEN=your-supabase-access-token
# SUPABASE_PROJECT_REF=your-project-ref
# SUPABASE_DB_PASSWORD=your-db-password

# ===========================================
# MISC
# ===========================================
NODE_ENV=development
