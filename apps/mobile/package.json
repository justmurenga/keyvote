{
  "name": "@myvote/mobile",
  "version": "1.0.0",
  "private": true,
  "main": "expo-router/entry",
  "scripts": {
    "dev": "cross-env EXPO_NO_DOCTOR=1 EXPO_OFFLINE=1 EXPO_NO_DEPENDENCY_VALIDATION=1 expo start . --host lan",
    "dev:clear": "cross-env EXPO_NO_DOCTOR=1 EXPO_OFFLINE=1 EXPO_NO_DEPENDENCY_VALIDATION=1 expo start . --host lan --clear",
    "android": "expo start --android",
    "ios": "expo start --ios",
    "dev:build": "cross-env EXPO_NO_DOCTOR=1 EXPO_OFFLINE=1 EXPO_NO_DEPENDENCY_VALIDATION=1 expo start --dev-client",
    "build:dev-apk": "eas build --profile development --platform android",
    "build:preview-apk": "eas build --profile preview --platform android",
    "build:preview-apk:local": "eas build --profile preview --platform android --local --output ./build/myvote-preview.apk",
    "build": "expo export --platform android",
    "lint": "eslint . --ext .ts,.tsx",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@babel/runtime": "^7.25.0",
    "@expo/vector-icons": "^14.0.0",
    "@myvote/shared": "workspace:*",
    "@react-native-async-storage/async-storage": "2.1.2",
    "@react-native-community/netinfo": "11.4.1",
    "@react-navigation/native": "^7.0.0",
    "@supabase/supabase-js": "^2.100.0",
    "@tanstack/react-query": "^5.62.0",
    "expo": "~53.0.0",
    "expo-constants": "~17.1.6",
    "expo-font": "~13.3.1",
    "expo-image": "~2.4.1",
    "expo-image-picker": "~16.1.4",
    "expo-linking": "~7.1.5",
    "expo-local-authentication": "~16.0.4",
    "expo-router": "~5.1.11",
    "expo-secure-store": "~14.2.3",
    "expo-splash-screen": "~0.30.9",
    "expo-status-bar": "~2.2.3",
    "minimatch": "^10.0.3",
    "react": "19.0.0",
    "react-native": "0.79.6",
    "react-native-gesture-handler": "~2.24.0",
    "react-native-reanimated": "~3.17.4",
    "react-native-safe-area-context": "5.4.0",
    "react-native-screens": "~4.11.1",
    "react-native-svg": "15.11.2",
    "react-native-url-polyfill": "^2.0.0",
    "zustand": "^5.0.0"
  },
  "devDependencies": {
    "@babel/core": "^7.25.0",
    "@babel/plugin-transform-flow-strip-types": "^7.27.1",
    "@types/minimatch": "^6.0.0",
    "@types/react": "~19.0.10",
    "@types/uuid": "^10.0.0",
    "cross-env": "^10.1.0",
    "eslint": "^8.57.0",
    "eslint-config-expo": "~9.2.0",
    "typescript": "~5.8.3"
  }
}
