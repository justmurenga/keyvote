{
  "name": "@myvote/mobile",
  "version": "1.0.0",
  "private": true,
  "main": "expo-router/entry",
  "scripts": {
    "dev": "cross-env EXPO_NO_DOCTOR=1 EXPO_OFFLINE=1 EXPO_NO_DEPENDENCY_VALIDATION=1 expo start . --host lan",
    "dev:clear": "cross-env EXPO_NO_DOCTOR=1 EXPO_OFFLINE=1 EXPO_NO_DEPENDENCY_VALIDATION=1 expo start . --host lan --clear",
    "android": "expo start --android",
    "ios": "expo start --ios",
    "dev:build": "cross-env EXPO_NO_DOCTOR=1 EXPO_OFFLINE=1 EXPO_NO_DEPENDENCY_VALIDATION=1 expo start --dev-client",
    "build:dev-apk": "eas build --profile development --platform android",
    "build": "expo export --platform android",
    "lint": "eslint . --ext .ts,.tsx",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@babel/runtime": "^7.25.0",
    "@expo/vector-icons": "^14.0.0",
    "@react-native-async-storage/async-storage": "~2.0.0",
    "@react-native-community/netinfo": "11.3.1",
    "@react-navigation/native": "^7.0.0",
    "@supabase/supabase-js": "^2.100.0",
    "@tanstack/react-query": "^5.62.0",
    "expo": "~53.0.0",
    "expo-constants": "~17.0.3",
    "expo-font": "~13.0.1",
    "expo-image": "~2.0.0",
    "expo-image-picker": "~16.0.2",
    "expo-linking": "~7.0.3",
    "expo-local-authentication": "~17.0.8",
    "expo-router": "~5.0.0",
    "expo-secure-store": "~14.0.0",
    "expo-splash-screen": "~0.29.15",
    "expo-status-bar": "~2.0.0",
    "minimatch": "^10.0.3",
    "react": "18.3.1",
    "react-native": "0.76.6",
    "react-native-gesture-handler": "~2.20.2",
    "react-native-reanimated": "~3.16.1",
    "react-native-safe-area-context": "~4.12.0",
    "react-native-screens": "~4.4.0",
    "react-native-svg": "15.8.0",
    "react-native-url-polyfill": "^2.0.0",
    "zustand": "^5.0.0"
  },
  "devDependencies": {
    "@babel/core": "^7.25.0",
    "@babel/plugin-transform-flow-strip-types": "^7.27.1",
    "@types/minimatch": "^6.0.0",
    "@types/react": "~18.3.0",
    "@types/uuid": "^10.0.0",
    "cross-env": "^10.1.0",
    "eslint": "^8.57.0",
    "eslint-config-expo": "~7.1.0",
    "typescript": "~5.3.3"
  }
}
